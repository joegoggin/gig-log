# Environment
APP_ENV=test

# CORS
WEB_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gig-log-test
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/gig-log-test
AUTO_APPLY_MIGRATIONS_ENABLED=false

# JWT Configuration
JWT_SECRET=integration-test-jwt-secret
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=60
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=120

# Resend Email Service
RESEND_API_KEY=re_test_api_key
RESEND_FROM_EMAIL=noreply@test.gig-log.local

# Auth Codes
AUTH_CODE_EXPIRY_SECONDS=60

# Logging
LOG_LEVEL=debug
LOG_VERBOSE=false
LOG_HTTP_MAX_BODY_BYTES=16384

# Integration testing
TEST_RESEND_BASE_URL=http://127.0.0.1:4010
